#!/usr/bin/env bash
# Prepend all filenames in a given directory with today's date of the form `YYYY-MM-DD-`.
# Ignore files that already have a matching date string.
#
# Usage:
#
#   addates <DIR>
#
# Examples:
#
#   addates myfolder
#   addates .
#
# author: andreasl

# extglob  - enables the `!(pattern)` negated glob to skip already-dated files.
# nullglob - makes an unmatched glob expand to nothing, so the loop is a no-op
#            when there is nothing to rename.
shopt -s extglob nullglob

cd "$1" || exit 1

today="$(date '+%Y-%m-%d')"
for file in !([0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*); do
    mv "$file" "${today}-${file}"
done
